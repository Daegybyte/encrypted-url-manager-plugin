{
  "manifest_version": 3,
  "name": "Encrypted URL Manager",
  "version": "2.2.4",
  "description": "Securely store and copy your profile URLs with one click.",
  "permissions": ["clipboardWrite"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self'; font-src 'self'; object-src 'self'"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Encrypted URL Manager",
    "default_icon": "./images/dp_d20_logo.png"
  }
}
